---
import OptimizedImage from "./OptimizedImage.astro";
import facturinSimple from "../assets/facturin/facturin_simple.png";
import ReactInit from "./ReactInit";
import type { Promocion } from "../lib/promociones";

interface Props {
  promocion?: Promocion | null;
  utmSource?: string;
  utmMedium?: string;
  utmCampaign?: string;
}

const { promocion, utmSource, utmMedium, utmCampaign } = Astro.props;
---
<ReactInit client:only="react" />

<div
	id="dropzone"
	class="bg-white rounded-[50px] border relative border-black py-12 md:py-16 px-8 md:px-16 cursor-pointer shadow-xl transition-all hover:border-gray-300 hover:shadow-lg"
	data-promocion={promocion ? JSON.stringify(promocion) : null}
	data-utm-source={utmSource ?? null}
	data-utm-medium={utmMedium ?? null}
	data-utm-campaign={utmCampaign ?? null}
>
	<div class="mb-12 flex flex-col md:flex-row items-center justify-center gap-6 md:gap-8">
		<div class="order-2 flex justify-end flex-1 md:order-1 shrink-0">
			<OptimizedImage
				src={facturinSimple}
				alt="Factura"
				width={192}
				class="w-20 h-auto"
				loading="eager"
			/>
		</div>
		<div class="order-1 md:order-2 flex flex-2 flex-col items-start text-center md:text-left">
			<p id="dropzone-text" class="text-black text-2xl md:text-4xl font-bold max-w-sm">Pincha y sube tu factura <span class="text-black underline underline-offset-2" style="text-decoration-color: var(--color-primary); text-decoration-thickness: 3px;">aquí</span></p>
			<p class="mt-2 flex items-center gap-1.5 text-sm text-gray-500">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 shrink-0 text-red-500" fill="currentColor" aria-hidden="true">
					<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8.5 15.5h-.75v1.25H7v-4h1.5c.83 0 1.5.67 1.5 1.5s-.67 1.25-1.5 1.25zm3.75.5c0 .83-.67 1.5-1.5 1.5H9.5v-4h1.25c.83 0 1.5.67 1.5 1.5v1zm3.25-2.5h-1.75v1h1.5v.75h-1.5v1.75H13v-4h2.5v.5z"/>
					<path d="M8.5 13.75H7.75v1h.75c.41 0 .75-.34.75-.5s-.34-.5-.75-.5zM10.75 13.75H10v2.5h.75c.41 0 .75-.34.75-.75v-1c0-.41-.34-.75-.75-.75z"/>
				</svg>
				Solo se admiten archivos PDF.
			</p>
			<p id="dropzone-error" class="mt-1 text-sm font-medium text-red-500 hidden"></p>
			<input
				type="file"
				id="file-input"
				accept=".pdf"
				class="hidden"
			/>
		</div>

	</div>
	<p class="text-sm text-center md:absolute md:bottom-4 md:right-5 md:left-5" style="color: var(--color-gris-light)">
		🔒 Los datos de tu factura están totalmente protegidos y solo serán utilizados para encontrar una tarifa más económica según tu consumo y precios.
	</p>
</div>

<div id="comparador-modal-root" aria-hidden="true"></div>

<script>
	import '../utils/comparadorDropzone';
</script>
