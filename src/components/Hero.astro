---
import ReviewsBar from "../widgets/ReviewsBar.astro";
import Comparador from "./Comparador.astro";
import type { Promocion } from "../lib/promociones";

interface Props {
	title: string;
	subtitle: string;
	promocion?: Promocion | null;
	utmSource?: string;
	utmMedium?: string;
	utmCampaign?: string;
}

const { title, subtitle, promocion, utmSource, utmMedium, utmCampaign } = Astro.props;
---

<section class="bg-primary pt-16 pb-56 px-6">
	<div class="max-w-4xl mx-auto text-center">
		{promocion && (
			<div class="promo-badge inline-flex items-center gap-2 rounded-full border-2 border-black bg-black px-4 py-2 font-bold mb-8 shadow-lg max-w-full">
				<span class="text-sm shrink-0">🎉</span>
				<span class="tracking-wide uppercase text-xs text-white whitespace-nowrap">{promocion.nombre}</span>
				{promocion.regalo && (
					<span class="rounded-full bg-primary text-black px-2 py-0.5 text-xs md:text-sm md:px-3 md:py-1 font-extrabold whitespace-nowrap shrink-0">
						{promocion.regalo}
					</span>
				)}
			</div>
		)}
		<h1 class="text-4xl md:text-5xl font-bold leading-tight mb-6" set:html={title} />
		<h2 class="text-xs md:text-lg text-gray-800 mb-12" set:html={subtitle} />
	</div>
</section>

<style>
	@keyframes heartbeat {
		0%   { transform: scale(1); }
		14%  { transform: scale(1.08); }
		28%  { transform: scale(1); }
		42%  { transform: scale(1.05); }
		56%  { transform: scale(1); }
		100% { transform: scale(1); }
	}
	.promo-badge {
		animation: heartbeat 1.6s ease-in-out infinite;
		transform-origin: center;
	}
</style>

<div class="px-6 -mt-55 relative pb-16">
	<div class="max-w-3xl mx-auto">
		<Comparador promocion={promocion} utmSource={utmSource} utmMedium={utmMedium} utmCampaign={utmCampaign} />
		<div class="mt-6 flex justify-center">
			<ReviewsBar />
		</div>
	</div>
</div>
